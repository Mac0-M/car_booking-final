# ===========================================
# Car Booking System - Backend Configuration
# ===========================================
# Copy this file to .env and update the values

# --- Server ---
PORT=3000

# --- JWT ---
JWT_SECRET=your_jwt_secret_key_here

# --- Super Admin ---
ENABLE_SUPER_ADMIN=true
SUPER_ADMIN_EMAIL=superadmin@admin.com
SUPER_ADMIN_PASSWORD=superadmin
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_PHONE=0800000000
